{
  "openapi": "3.0.3",
  "info": {
    "title": "OneMoreTaskTracker Plan API",
    "version": "v1",
    "description": "REST surface emitted by OneMoreTaskTracker.Api for the feature planning (Gantt) experience. Backed by gRPC into OneMoreTaskTracker.Features / .Tasks / .Users. All dates are ISO yyyy-MM-dd strings or null. Hand-rolled for iteration 1 of the feature-stage-planning feature (api-contract.md v1); Swashbuckle is a follow-up."
  },
  "servers": [
    { "url": "http://localhost:5000", "description": "Local dev" }
  ],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/api/auth/health": {
      "get": {
        "summary": "Liveness probe — returns {status:'ok'}.",
        "description": "Anonymous, no upstream calls. Used by deployment + GAN harness (BE_HEALTH_URL).",
        "tags": ["auth"],
        "security": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["status"],
                  "properties": { "status": { "type": "string", "enum": ["ok"] } }
                }
              }
            }
          }
        }
      }
    },
    "/api/plan/features": {
      "get": {
        "summary": "List features visible to the caller.",
        "description": "Optional `windowStart` / `windowEnd` query params (ISO yyyy-MM-dd) constrain results to features whose plan overlaps the window. Window semantics: `windowStart` is inclusive on `plannedEnd`; `windowEnd` is exclusive on `plannedStart`; features with null `plannedStart` and/or `plannedEnd` are always included. Bad date format or `windowStart > windowEnd` returns 400 `Invalid request data` and the upstream gRPC service is NOT called.",
        "tags": ["plan"],
        "parameters": [
          { "name": "scope", "in": "query", "required": false, "schema": { "type": "string", "enum": ["mine", "all"] } },
          { "name": "state", "in": "query", "required": false, "schema": { "$ref": "#/components/schemas/FeatureState" } },
          { "name": "windowStart", "in": "query", "required": false, "description": "ISO yyyy-MM-dd. Inclusive on plannedEnd.", "schema": { "type": "string", "format": "date" } },
          { "name": "windowEnd", "in": "query", "required": false, "description": "ISO yyyy-MM-dd. Exclusive on plannedStart.", "schema": { "type": "string", "format": "date" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/FeatureSummary" } }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "summary": "Create a new feature (Manager only).",
        "description": "Creates the feature and atomically materializes 5 empty stage plans (one per FeatureState ordinal). `managerUserId` is derived from the caller's JWT and MUST NOT be sent in the body.",
        "tags": ["plan"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CreateFeaturePayload" } }
          }
        },
        "responses": {
          "200": {
            "description": "Created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/FeatureSummary" } }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/plan/features/bounds": {
      "get": {
        "summary": "Dataset-wide earliest planned start and latest planned end for the caller's visible features.",
        "description": "Used by the Gantt to render the hard-bound cushions at dataset extents. Both fields are nullable when the caller's dataset has no planned dates (purely-unscheduled or empty); empty dataset still returns 200 (NOT 404). The FE applies the ±30-day cushion client-side. `scope` and `state` are accepted for parity with the list endpoint but are ignored at the service layer in v1; bounds always reflect the caller's full manager-visible dataset.",
        "tags": ["plan"],
        "parameters": [
          { "name": "scope", "in": "query", "required": false, "schema": { "type": "string", "enum": ["mine", "all"] } },
          { "name": "state", "in": "query", "required": false, "schema": { "$ref": "#/components/schemas/FeatureState" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "headers": {
              "Cache-Control": {
                "description": "private, max-age=10 — bounds are slow-moving but the FE re-fetches on focus and after date-bearing inline edits.",
                "schema": { "type": "string" }
              }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FeatureBounds" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/plan/features/{id}": {
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int32" } }
      ],
      "get": {
        "summary": "Get a single feature with attached tasks, lead, mini-team, and resolved stage-plan performers.",
        "tags": ["plan"],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/FeatureDetail" } }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "patch": {
        "summary": "Update a feature (Manager only).",
        "description": "All body fields are optional — omitted means unchanged. When `stagePlans` is present it MUST contain exactly 5 entries, one per FeatureState value, in any order. The server re-orders canonically. Omitted stagePlans leaves existing plans untouched. Empty array (`[]`) is rejected with 400. Derived `plannedStart` / `plannedEnd` on the feature are recomputed server-side as min/max over populated stage dates.",
        "tags": ["plan"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/UpdateFeaturePayload" } }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/FeatureSummary" } }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "502": { "$ref": "#/components/responses/BadGateway" }
        }
      }
    },
    "/api/plan/features/{id}/title": {
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int32" } },
        { "name": "If-Match", "in": "header", "required": false, "description": "Optional optimistic-concurrency token; current feature.version from the last read. Missing header = advisory mode (last-write-wins) in iter 1.", "schema": { "type": "string" } }
      ],
      "patch": {
        "summary": "Update a feature's title in place (inline edit — Manager only).",
        "description": "Trimmed server-side; 1..200 chars after trim. Empty or whitespace-only titles are rejected as 400. Returns the refreshed FeatureSummary with a bumped `version`.",
        "tags": ["plan"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/UpdateFeatureTitlePayload" } }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FeatureSummary" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" },
          "502": { "$ref": "#/components/responses/BadGateway" }
        }
      }
    },
    "/api/plan/features/{id}/description": {
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int32" } },
        { "name": "If-Match", "in": "header", "required": false, "schema": { "type": "string" } }
      ],
      "patch": {
        "summary": "Update a feature's description (inline edit — Manager only).",
        "description": "0..4000 chars after trim; empty or null clears the field. Leading whitespace preserved; trailing whitespace trimmed.",
        "tags": ["plan"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/UpdateFeatureDescriptionPayload" } }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FeatureSummary" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" },
          "502": { "$ref": "#/components/responses/BadGateway" }
        }
      }
    },
    "/api/plan/features/{id}/stages/{stage}/owner": {
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int32" } },
        { "name": "stage", "in": "path", "required": true, "schema": { "$ref": "#/components/schemas/FeatureState" } },
        { "name": "If-Match", "in": "header", "required": false, "description": "Optional stage-scoped optimistic-concurrency token (stagePlans[].stageVersion).", "schema": { "type": "string" } }
      ],
      "patch": {
        "summary": "Reassign a single stage's owner (inline edit — Manager only).",
        "description": "`stageOwnerUserId` must be null (clear) or a positive integer on the feature manager's roster. Role-prefixed naming per microservices/contracts.md. Stage path segment is case-insensitive (`development`, `Development`, `DEVELOPMENT` all canonicalise to the same FeatureState).",
        "tags": ["plan"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/UpdateStageOwnerPayload" } }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FeatureSummary" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" },
          "502": { "$ref": "#/components/responses/BadGateway" }
        }
      }
    },
    "/api/plan/features/{id}/stages/{stage}/planned-start": {
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int32" } },
        { "name": "stage", "in": "path", "required": true, "schema": { "$ref": "#/components/schemas/FeatureState" } },
        { "name": "If-Match", "in": "header", "required": false, "schema": { "type": "string" } }
      ],
      "patch": {
        "summary": "Update a single stage's planned start date (inline edit — Manager only).",
        "description": "ISO yyyy-MM-dd string or null to clear. Year must be 2000..2100 inclusive (`Use a real release date` otherwise). Must be on or before the stage's existing plannedEnd when both are set. Cross-stage chronological order is enforced — violation returns 422 with `conflict.kind = 'overlap'` and `conflict.with` set to the neighbour stage. Stage path segment is case-insensitive. Derived feature.plannedStart recomputed server-side.",
        "tags": ["plan"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/UpdateStagePlannedStartPayload" } }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FeatureSummary" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" },
          "502": { "$ref": "#/components/responses/BadGateway" }
        }
      }
    },
    "/api/plan/features/{id}/stages/{stage}/planned-end": {
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int32" } },
        { "name": "stage", "in": "path", "required": true, "schema": { "$ref": "#/components/schemas/FeatureState" } },
        { "name": "If-Match", "in": "header", "required": false, "schema": { "type": "string" } }
      ],
      "patch": {
        "summary": "Update a single stage's planned end date (inline edit — Manager only).",
        "description": "Symmetric to planned-start. Year must be 2000..2100 inclusive. Must be on or after the stage's existing plannedStart. Cross-stage chronological order is enforced — violation returns 422 with `conflict.kind = 'overlap'` and `conflict.with` set to the neighbour stage. Stage path segment is case-insensitive.",
        "tags": ["plan"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/UpdateStagePlannedEndPayload" } }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FeatureSummary" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" },
          "502": { "$ref": "#/components/responses/BadGateway" }
        }
      }
    },
    "/api/plan/features/{id}/tasks/{jiraId}": {
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "integer", "format": "int32" } },
        { "name": "jiraId", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "post": {
        "summary": "Attach a task (by Jira id) to a feature (Manager only).",
        "tags": ["plan"],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/FeatureSummary" } }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "summary": "Detach a task from a feature, reassigning it to another feature (Manager only).",
        "tags": ["plan"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/DetachTaskBody" } }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/FeatureSummary" } }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request data.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "Unauthorized": {
        "description": "Authentication required.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "Forbidden": {
        "description": "Permission denied.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "NotFound": {
        "description": "Resource not found.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "UnprocessableEntity": {
        "description": "Validation error. On cross-stage chronological-order violations the body extends to `{ error, conflict: { kind: 'overlap' | 'order' | 'rangeInvalid', with: <stage> } }` so the FE can highlight the offending neighbour stage.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ConflictError" } } }
      },
      "BadGateway": {
        "description": "Upstream service temporarily unavailable.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "Conflict": {
        "description": "Version mismatch (concurrent edit detected). Body includes a `conflict` object with `kind:'version'` and the server's current `currentVersion` when the handler reports a concurrency conflict.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ConflictError" } } }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": ["error"],
        "properties": { "error": { "type": "string" } }
      },
      "ConflictError": {
        "type": "object",
        "description": "Extended error envelope emitted on 409/422 when the handler reports a concurrency or stage-order conflict. Clients unaware of `conflict` fall back to the bare `error` string.",
        "required": ["error"],
        "properties": {
          "error": { "type": "string", "description": "Public-facing message such as 'Updated by someone else' or 'Stage order violation'." },
          "conflict": {
            "type": "object",
            "description": "Structured conflict context. Absent when the upstream did not supply one.",
            "required": ["kind"],
            "properties": {
              "kind": { "type": "string", "enum": ["version", "overlap"] },
              "currentVersion": { "type": "integer", "format": "int32", "description": "Server's current version (kind='version')." },
              "with": { "$ref": "#/components/schemas/FeatureState" }
            }
          }
        }
      },
      "FeatureState": {
        "type": "string",
        "enum": ["CsApproving", "Development", "Testing", "EthalonTesting", "LiveRelease"]
      },
      "StagePlan": {
        "type": "object",
        "description": "List-row stage plan — id-only performer. `stageVersion` is rolled out additively (api-contract.md §rollout-tolerance) and is therefore NOT in the required set; old payloads that predate the inline-edit feature may omit it.",
        "required": ["stage", "plannedStart", "plannedEnd", "performerUserId"],
        "properties": {
          "stage": { "$ref": "#/components/schemas/FeatureState" },
          "plannedStart": { "type": "string", "format": "date", "nullable": true },
          "plannedEnd":   { "type": "string", "format": "date", "nullable": true },
          "performerUserId": { "type": "integer", "format": "int32", "nullable": true },
          "stageVersion": { "type": "integer", "format": "int32", "description": "Per-stage optimistic-concurrency token; consumed by the FE inline editor's If-Match header for stage-scoped PATCHes." }
        }
      },
      "StagePlanDetail": {
        "type": "object",
        "description": "Detail stage plan — resolved performer mini-member. `performer` is null when the stage is unassigned OR when the stored performer id is no longer on the manager's roster (stale). In the stale case `performerUserId` is still emitted so the FE can render the 'Performer no longer on team' state.",
        "required": ["stage", "plannedStart", "plannedEnd", "performerUserId", "performer"],
        "properties": {
          "stage": { "$ref": "#/components/schemas/FeatureState" },
          "plannedStart": { "type": "string", "format": "date", "nullable": true },
          "plannedEnd":   { "type": "string", "format": "date", "nullable": true },
          "performerUserId": { "type": "integer", "format": "int32", "nullable": true },
          "performer": {
            "nullable": true,
            "allOf": [ { "$ref": "#/components/schemas/MiniTeamMember" } ]
          },
          "stageVersion": { "type": "integer", "format": "int32", "description": "Per-stage optimistic-concurrency token." }
        }
      },
      "StagePlanPayload": {
        "type": "object",
        "required": ["stage"],
        "properties": {
          "stage": { "$ref": "#/components/schemas/FeatureState" },
          "plannedStart": { "type": "string", "format": "date", "nullable": true },
          "plannedEnd":   { "type": "string", "format": "date", "nullable": true },
          "performerUserId": { "type": "integer", "format": "int32", "nullable": true }
        }
      },
      "MiniTeamMember": {
        "type": "object",
        "required": ["userId", "email", "displayName", "role"],
        "properties": {
          "userId":      { "type": "integer", "format": "int32" },
          "email":       { "type": "string" },
          "displayName": { "type": "string" },
          "role":        { "type": "string" }
        }
      },
      "AttachedTask": {
        "type": "object",
        "required": ["id", "jiraId", "state", "userId"],
        "properties": {
          "id":     { "type": "integer", "format": "int32" },
          "jiraId": { "type": "string" },
          "state":  { "type": "string" },
          "userId": { "type": "integer", "format": "int32" }
        }
      },
      "FeatureSummary": {
        "type": "object",
        "required": ["id","title","description","state","plannedStart","plannedEnd","leadUserId","managerUserId","taskCount","taskIds","stagePlans"],
        "properties": {
          "id":            { "type": "integer", "format": "int32" },
          "title":         { "type": "string", "maxLength": 200 },
          "description":   { "type": "string", "nullable": true, "maxLength": 4000 },
          "state":         { "$ref": "#/components/schemas/FeatureState" },
          "plannedStart":  { "type": "string", "format": "date", "nullable": true, "description": "Derived server-side as min(stagePlans[].plannedStart)." },
          "plannedEnd":    { "type": "string", "format": "date", "nullable": true, "description": "Derived server-side as max(stagePlans[].plannedEnd)." },
          "leadUserId":    { "type": "integer", "format": "int32" },
          "managerUserId": { "type": "integer", "format": "int32" },
          "taskCount":     { "type": "integer", "format": "int32" },
          "taskIds":       { "type": "array", "items": { "type": "integer", "format": "int32" } },
          "stagePlans": {
            "type": "array",
            "minItems": 5,
            "maxItems": 5,
            "items": { "$ref": "#/components/schemas/StagePlan" },
            "description": "Always length 5, canonical FeatureState order. Performer is id-only on list rows."
          },
          "version": { "type": "integer", "format": "int32", "description": "Monotonically-increasing row version used as an optimistic-concurrency token. Bumped by every inline-edit PATCH." }
        }
      },
      "FeatureBounds": {
        "type": "object",
        "description": "Dataset-wide planned-date extents for the caller's visible features. Both fields are nullable when the dataset has no planned dates.",
        "required": ["earliestPlannedStart", "latestPlannedEnd"],
        "properties": {
          "earliestPlannedStart": { "type": "string", "format": "date", "nullable": true, "description": "Minimum non-null plannedStart across the caller's visible features." },
          "latestPlannedEnd":     { "type": "string", "format": "date", "nullable": true, "description": "Maximum non-null plannedEnd across the caller's visible features." }
        }
      },
      "FeatureDetail": {
        "type": "object",
        "required": ["feature","tasks","lead","miniTeam","stagePlans"],
        "properties": {
          "feature":  { "$ref": "#/components/schemas/FeatureSummary" },
          "tasks":    { "type": "array", "items": { "$ref": "#/components/schemas/AttachedTask" } },
          "lead":     { "$ref": "#/components/schemas/MiniTeamMember" },
          "miniTeam": { "type": "array", "items": { "$ref": "#/components/schemas/MiniTeamMember" }, "description": "Deduped union of task assignees, lead, and every populated stage-plan performer." },
          "stagePlans": {
            "type": "array",
            "minItems": 5,
            "maxItems": 5,
            "items": { "$ref": "#/components/schemas/StagePlanDetail" },
            "description": "Always length 5, canonical FeatureState order. Each entry carries a resolved performer mini-member."
          }
        }
      },
      "CreateFeaturePayload": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title":        { "type": "string", "maxLength": 200 },
          "description":  { "type": "string", "nullable": true, "maxLength": 4000 },
          "leadUserId":   { "type": "integer", "format": "int32", "nullable": true },
          "plannedStart": { "type": "string", "format": "date", "nullable": true, "description": "Legacy feature-level date; prefer authoring per-stage plans via PATCH." },
          "plannedEnd":   { "type": "string", "format": "date", "nullable": true, "description": "Legacy feature-level date; prefer authoring per-stage plans via PATCH." }
        }
      },
      "UpdateFeaturePayload": {
        "type": "object",
        "description": "All fields optional. Omitted `stagePlans` means do-not-touch; when present MUST have exactly 5 entries with unique stage names.",
        "properties": {
          "title":         { "type": "string", "nullable": true, "maxLength": 200 },
          "description":   { "type": "string", "nullable": true, "maxLength": 4000 },
          "leadUserId":    { "type": "integer", "format": "int32", "nullable": true },
          "plannedStart":  { "type": "string", "format": "date", "nullable": true },
          "plannedEnd":    { "type": "string", "format": "date", "nullable": true },
          "state":         { "$ref": "#/components/schemas/FeatureState" },
          "stagePlans": {
            "type": "array",
            "nullable": true,
            "minItems": 5,
            "maxItems": 5,
            "items": { "$ref": "#/components/schemas/StagePlanPayload" }
          }
        }
      },
      "DetachTaskBody": {
        "type": "object",
        "required": ["reassignToFeatureId"],
        "properties": {
          "reassignToFeatureId": { "type": "integer", "format": "int32", "minimum": 1 }
        }
      },
      "UpdateFeatureTitlePayload": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string", "minLength": 1, "maxLength": 200 }
        }
      },
      "UpdateFeatureDescriptionPayload": {
        "type": "object",
        "required": ["description"],
        "properties": {
          "description": { "type": "string", "nullable": true, "maxLength": 4000 }
        }
      },
      "UpdateStageOwnerPayload": {
        "type": "object",
        "required": ["stageOwnerUserId"],
        "description": "Role-prefixed naming: `stageOwnerUserId` is an opaque cross-service reference to the Users service. Null clears the assignment.",
        "properties": {
          "stageOwnerUserId": { "type": "integer", "format": "int32", "nullable": true, "minimum": 1 }
        }
      },
      "UpdateStagePlannedStartPayload": {
        "type": "object",
        "required": ["plannedStart"],
        "properties": {
          "plannedStart": { "type": "string", "format": "date", "nullable": true }
        }
      },
      "UpdateStagePlannedEndPayload": {
        "type": "object",
        "required": ["plannedEnd"],
        "properties": {
          "plannedEnd": { "type": "string", "format": "date", "nullable": true }
        }
      }
    }
  }
}
