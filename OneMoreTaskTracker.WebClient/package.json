    "eslint-plugin-storybook": "^10.3.5",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
